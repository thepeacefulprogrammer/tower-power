# Copy to .remote-publish.env and fill in your own values.
# This file is sourced by scripts/publish-vm.sh and scripts/stop-publish-vm.sh.
# If this file exists, ./dev.sh will also start the remote publish tunnel automatically.

DEPLOY_HOST=your-user@example-host
SSH_KEY=$HOME/.ssh/id_ed25519
LOCAL_PORT=8080
REMOTE_SOCKET=/path/to/tower-power.sock
PUBLIC_HOST=your-public-host.example.com
